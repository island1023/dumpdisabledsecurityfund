<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dumpdisabledsecurityfund.mapper.CompanyMapper">

    <resultMap id="BaseResultMap" type="com.example.dumpdisabledsecurityfund.entity.Company">
        <id column="id" property="id"/>
        <result column="unified_social_credit_code" property="unifiedSocialCreditCode"/>
        <result column="name" property="name"/>
        <result column="region_id" property="regionId"/>
        <result column="legal_person" property="legalPerson"/>
        <result column="contact_phone" property="contactPhone"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO company(
            unified_social_credit_code, name, region_id, legal_person,
            contact_phone, status, create_time, update_time
        ) VALUES(
                    #{unifiedSocialCreditCode}, #{name}, #{regionId}, #{legalPerson},
                    #{contactPhone}, #{status}, #{createTime}, #{updateTime}
                )
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM company WHERE id = #{id}
    </select>

    <select id="selectByCreditCode" resultMap="BaseResultMap">
        SELECT * FROM company WHERE unified_social_credit_code = #{creditCode}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM company ORDER BY id DESC
    </select>

    <select id="selectByRegionId" resultMap="BaseResultMap">
        SELECT * FROM company WHERE region_id = #{regionId} ORDER BY id DESC
    </select>

    <select id="selectByStatus" resultMap="BaseResultMap">
        SELECT * FROM company WHERE status = #{status} ORDER BY id DESC
    </select>

    <select id="countAll" resultType="int">
        SELECT COUNT(1) FROM company
    </select>

    <select id="countByRegionId" resultType="int">
        SELECT COUNT(1) FROM company WHERE region_id = #{regionId}
    </select>

    <update id="updateById">
        UPDATE company
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="regionId != null">region_id = #{regionId},</if>
            <if test="legalPerson != null">legal_person = #{legalPerson},</if>
            <if test="contactPhone != null">contact_phone = #{contactPhone},</if>
            <if test="status != null">status = #{status},</if>
            update_time = #{updateTime}
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM company WHERE id = #{id}
    </delete>

</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.dumpdisabledsecurityfund.mapper.OperationLogMapper">

    <resultMap id="BaseResultMap" type="com.example.dumpdisabledsecurityfund.entity.OperationLog">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="operation_type" property="operationType"/>
        <result column="target_table" property="targetTable"/>
        <result column="target_id" property="targetId"/>
        <result column="detail" property="detail"/>
        <result column="ip_address" property="ipAddress"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO operation_log(
            user_id, operation_type, target_table, target_id,
            detail, ip_address, create_time
        ) VALUES(
                    #{userId}, #{operationType}, #{targetTable}, #{targetId},
                    #{detail}, #{ipAddress}, #{createTime}
                )
    </insert>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT * FROM operation_log WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="BaseResultMap">
        SELECT * FROM operation_log
        ORDER BY create_time DESC
    </select>

    <select id="selectByUserId" resultMap="BaseResultMap">
        SELECT * FROM operation_log
        WHERE user_id = #{userId}
        ORDER BY create_time DESC
    </select>

    <select id="selectByOperationType" resultMap="BaseResultMap">
        SELECT * FROM operation_log
        WHERE operation_type = #{operationType}
        ORDER BY create_time DESC
    </select>

    <select id="selectRecentLogs" resultMap="BaseResultMap">
        SELECT * FROM operation_log
        ORDER BY create_time DESC
            LIMIT #{limit}
    </select>

    <select id="countByUserId" resultType="int">
        SELECT COUNT(1) FROM operation_log WHERE user_id = #{userId}
    </select>

    <delete id="deleteById">
        DELETE FROM operation_log WHERE id = #{id}
    </delete>

    <delete id="deleteBeforeDate">
        DELETE FROM operation_log
        WHERE create_time &lt; #{date}
    </delete>

</mapper>
